{
    "name": "root-api-util",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "libraries/root-api-util/src",
    "projectType": "library",
    "tags": [],
    "targets": {
        "test": {
            "executor": "nx:run-commands",
            "options": {
                "command": "vitest run --config libraries/root-api-util/vitest.config.mts"
            }
        },
        "build": {
            "executor": "@nx/js:tsc",
            "outputs": ["{options.outputPath}"],
            "options": {
                "outputPath": "dist/libraries/root-api-util",
                "main": "libraries/root-api-util/src/index.ts",
                "tsConfig": "libraries/root-api-util/tsconfig.lib.json",
                "assets": ["libraries/root-api-util/*.md"]
            }
        }
    }
}
